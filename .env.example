# ============================================================
# Brasileirão Analytics — Variáveis de Ambiente (exemplo)
# ============================================================
# Copie para .env (desenvolvimento local) e preencha os valores.
# Em produção (GitHub Actions), cada variável vira um Secret do
# repositório: Settings → Secrets and variables → Actions.
# ============================================================

# Contas do Ogol para o scraping (formato: email:senha,email:senha)
# A primeira é a principal; as demais são fallback quando o limite
# de visualizações da conta é atingido.
OGOL_ACCOUNTS="email1@exemplo.com:senha1,email2@exemplo.com:senha2"

# ID da planilha do Google Sheets de destino
# (o trecho entre /d/ e /edit na URL da planilha)
SPREADSHEET_ID="1AbC...xyz"

# Conteúdo JSON integral do credentials.json da Service Account.
# Em desenvolvimento local, alternativamente deixe o arquivo
# credentials.json na raiz do projeto (ignorado pelo git).
# GOOGLE_CREDENTIALS='{"type": "service_account", ...}'

# Anos a extrair: "todos" | "atual" | lista "2024,2025"
ANOS_EXTRACAO="todos"

# Modo de escrita no Sheets: "overwrite" (padrão) | "append"
LOAD_MODO="overwrite"
